{
    "name": "philiprehberger/cron-expression-builder",
    "description": "Fluent cron expression builder with human-readable methods",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "cron",
        "schedule",
        "expression",
        "builder",
        "time"
    ],
    "authors": [
        {
            "name": "Philip Rehberger"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^1.12|^2.0"
    },
    "autoload": {
        "psr-4": {
            "PhilipRehberger\\CronBuilder\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhilipRehberger\\CronBuilder\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
